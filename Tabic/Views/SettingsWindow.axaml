<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Tabic.ViewModels"
        x:Class="Tabic.Views.SettingsWindow"
        x:DataType="vm:SettingsWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="设置"
        Width="500"
        Height="460"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Design.DataContext>
        <vm:SettingsWindowViewModel/>
    </Design.DataContext>

    <Grid Margin="20" RowDefinitions="*,Auto">
        <!-- 设置表单 -->
        <StackPanel Grid.Row="0" Spacing="16">
            <TextBlock Text="LLM 设置"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <!-- API 地址 -->
            <Grid ColumnDefinitions="120,*">
                <TextBlock Grid.Column="0"
                           Text="API 地址"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Column="1"
                         Text="{Binding ApiUrl}"
                         Watermark="https://api.openai.com/v1/chat/completions"/>
            </Grid>

            <!-- API 密钥 -->
            <Grid ColumnDefinitions="120,*">
                <TextBlock Grid.Column="0"
                           Text="API 密钥"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Column="1"
                         Text="{Binding ApiKey}"
                         PasswordChar="*"
                         Watermark="sk-xxxxxxxx"/>
            </Grid>

            <!-- 模型名称 -->
            <Grid ColumnDefinitions="120,*">
                <TextBlock Grid.Column="0"
                           Text="模型名称"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Column="1"
                         Text="{Binding Model}"
                         Watermark="gpt-4o"/>
            </Grid>

            <!-- 自定义请求头 -->
            <Grid ColumnDefinitions="120,*">
                <TextBlock Grid.Column="0"
                           Text="自定义请求头"
                           VerticalAlignment="Top"
                           Margin="0,4,0,0"/>
                <StackPanel Grid.Column="1" Spacing="6">
                    <!-- 表头 -->
                    <Grid ColumnDefinitions="*,*,Auto">
                        <TextBlock Grid.Column="0" Text="Key" FontSize="12" Opacity="0.6"/>
                        <TextBlock Grid.Column="1" Text="Value" FontSize="12" Opacity="0.6"/>
                    </Grid>
                    <!-- 请求头列表 -->
                    <ItemsControl ItemsSource="{Binding Headers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:HeaderItemViewModel">
                                <Grid ColumnDefinitions="*,*,Auto" Margin="0,2,0,0">
                                    <TextBox Grid.Column="0"
                                             Text="{Binding Key}"
                                             Margin="0,0,4,0"
                                             FontSize="13"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Value}"
                                             Margin="4,0,4,0"
                                             FontSize="13"/>
                                    <Button Grid.Column="2"
                                            Content="✕"
                                            Command="{Binding $parent[ItemsControl].((vm:SettingsWindowViewModel)DataContext).RemoveHeaderCommand}"
                                            CommandParameter="{Binding}"
                                            Width="28"
                                            Padding="0"
                                            HorizontalContentAlignment="Center"
                                            FontSize="12"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="+ 添加请求头"
                            Command="{Binding AddHeaderCommand}"
                            HorizontalAlignment="Left"
                            FontSize="13"
                            Padding="8,4"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="10"
                    Margin="0,20,0,0">
            <Button Content="保存"
                    HorizontalContentAlignment="Center"
                    Command="{Binding SaveCommand}"
                    Width="80"/>
            <Button Content="取消"
                    HorizontalContentAlignment="Center"
                    Command="{Binding CancelCommand}"
                    Width="80"/>
        </StackPanel>
    </Grid>

</Window>
