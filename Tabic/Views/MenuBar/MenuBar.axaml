<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Tabic.ViewModels"
             x:Class="Tabic.Views.MenuBar.MenuBar"
             x:DataType="vm:MainWindowViewModel">

    <Menu Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
        <MenuItem Header="文件">
            <MenuItem Header="新建项目" Command="{Binding NewProjectCommand}" InputGesture="Ctrl+N"/>
            <MenuItem Header="打开项目" Command="{Binding OpenProjectCommand}" InputGesture="Ctrl+O"/>
            <MenuItem Header="保存项目" Command="{Binding SaveProjectCommand}" InputGesture="Ctrl+S"/>
            <Separator/>
            <MenuItem Header="退出" Command="{Binding ExitCommand}"/>
        </MenuItem>
        <MenuItem Header="编辑">
            <MenuItem Header="添加角色" Command="{Binding AddRoleCommand}" InputGesture="Ctrl+R"/>
            <MenuItem Header="添加时间点" Command="{Binding AddTimePointCommand}" InputGesture="Ctrl+T"/>
            <Separator/>
            <MenuItem Header="删除选中角色" Command="{Binding RemoveRoleCommand}"/>
            <MenuItem Header="删除选中时间点" Command="{Binding RemoveTimePointCommand}"/>
        </MenuItem>
        <MenuItem Header="工具">
            <MenuItem Header="设置" Command="{Binding OpenSettingsCommand}"/>
        </MenuItem>
        <MenuItem Header="帮助">
            <MenuItem Header="关于 Tabic" Command="{Binding AboutCommand}"/>
        </MenuItem>
    </Menu>

</UserControl>
