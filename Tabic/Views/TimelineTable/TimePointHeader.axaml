<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Tabic.ViewModels"
             x:Class="Tabic.Views.TimelineTable.TimePointHeader"
             x:DataType="vm:TableRowViewModel">

    <Border Background="Transparent"
            Padding="12,8"
            PointerPressed="OnPointerPressed">
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="在上方添加时间点"
                          Command="{Binding $parent[ItemsControl].((vm:TimelineTableViewModel)DataContext).InsertTimePointAboveCommand}" />
                <MenuItem Header="在下方添加时间点"
                          Command="{Binding $parent[ItemsControl].((vm:TimelineTableViewModel)DataContext).InsertTimePointBelowCommand}" />
            </ContextMenu>
        </Border.ContextMenu>
        <TextBlock Text="{Binding TimePoint.Name}"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Foreground="#555555"
                   FontSize="13"/>
    </Border>

</UserControl>
