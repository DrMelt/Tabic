<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Tabic.ViewModels"
             x:Class="Tabic.Views.TimelineTable.TimePointHeader"
             x:DataType="vm:TableRowViewModel">

    <Border Background="Transparent"
            Padding="12,8">
        <TextBlock Text="{Binding TimePoint.Name}"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Foreground="#555555"
                   FontSize="13"/>
    </Border>

</UserControl>
